{
  "name": "voice-yeeter",
  "version": "1.0.0",
  "description": "A lightweight Discord bot built with discord.js that disconnects all users from voice channels after a configurable timer. Slash-command powered, permission-aware, and ready for containerized deployment.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx index.ts",
    "deploy": "pnpm build && node dist/deploy-commands.js",
    "test": "echo \"No tests configured\""
  },
  "keywords": ["discord bot", "voice channel", "timer", "slash commands", "discord.js", "typescript"],
  "author": "Iconical (https://iconical.dev)",
  "homepage": "https://iconical.dev",
  "funding": "https://iconical.dev/sponsor",
  "license": "ISC",
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
